PORT=3000
NODE_ENV=development
TRUST_PROXY=false

# Resume — apna PDF yahan rakho: public/resume/resume.pdf
RESUME_FILE=resume.pdf
RESUME_DOWNLOAD_NAME=Shubham-Rathod-Resume.pdf

# Email (Gmail example — App Password use karo, normal password nahi)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your.email@gmail.com
SMTP_PASS=your_gmail_app_password
CONTACT_TO=your.email@gmail.com
CONTACT_FROM=Portfolio <your.email@gmail.com>
